# ============================================================
# SoloDeveloping — AI configuration (server-side only)
# Copy to .env.local for dev, or set in Vercel Project Settings.
# ============================================================

# Which provider to use: "groq" | "gemini" | "anthropic"
# If left blank, the server auto-detects based on which key below is set.
AI_PROVIDER=

# --- Groq (fast + generous free tier) -> https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini -> https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Anthropic Claude -> https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# NOTE: Set ONE provider's key. The app works without a key too (it falls back
# to a strong rule-based local planner), but AI mode unlocks the legend voices.
